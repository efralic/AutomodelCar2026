<launch>
  <!--
    SIMULATION: Navigation WITH STATIC Obstacles - TMR 2026
    Launches EVERYTHING: Gazebo + Robot + Obstacles + Navigation
  -->
  
  <!-- ========== GAZEBO SETUP ========== -->
  
  <!-- Launch Gazebo with TMR 2021 world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find autonomos_gazebo_simulation)/worlds/TMR2021.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
    <arg name="verbose" value="true"/>
  </include>
  
  <!-- Spawn AutoNOMOS Mini Robot -->
  <include file="$(find bring_up)/launch/spawn_autoNOMOS_mini.launch">
    <arg name="robot_name" value="AutoModelMini"/>
    <arg name="pos_x" value="2.5"/>
    <arg name="pos_y" value="3.3"/>
    <arg name="pos_z" value="0.17"/>
    <arg name="yaw" value="3.14159"/>
  </include>
  
  <!-- Spawn Static Obstacles (Test 2) -->
  <node name="spawn_test2_obstacles" pkg="bring_up" type="test2_start.py" 
        output="screen" launch-prefix="bash -c 'sleep 3; $0 $@'"/>
  
  <!-- ========== NAVIGATION NODES ========== -->
  
  <!-- Lane Detection -->
  <node name="lane_detection" pkg="lane_detection" type="lane_detection" 
        output="screen" respawn="false">
    <remap from="/app/camera/rgb/image_raw" to="/AutoModelMini/camera/rgb/image_raw"/>
  </node>
  
  <!-- Object Detection (LIDAR) -->
  <node name="object_detection" pkg="object_detection" type="object_detection" 
        output="screen" respawn="false">
    <remap from="/scan" to="/AutoModelMini/scan"/>
  </node>
  
  <!-- Master Controller for Static Obstacles -->
  <node name="Master_static" pkg="control" type="Master_static" 
        output="screen" respawn="false"/>
  
</launch>
