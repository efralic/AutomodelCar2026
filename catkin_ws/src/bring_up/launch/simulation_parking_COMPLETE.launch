<launch>
  <!-- Gazebo + Mundo Parking -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find autonomos_gazebo_simulation)/worlds/TMR2021_parking.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
  </include>
  
  <!-- Spawn Robot + Parking Setup -->
  <node name="spawn_test4_parking" pkg="bring_up" type="test4_start.py" 
        output="screen" launch-prefix="bash -c 'sleep 3; $0 $@'"/>
  
  <!-- Lane Detection -->
  <node name="lane_detection" pkg="lane_detection" type="lane_detection" output="screen">
    <remap from="/app/camera/rgb/image_raw" to="/AutoModelMini/camera/rgb/image_raw"/>
  </node>
  
  <!-- Object Detection Parking -->
  <node name="object_detection_parking" pkg="object_detection_parking" 
        type="object_detection_parking" output="screen">
    <remap from="/AutoModelMini/scan" to="/scan"/>
  </node>
  
  <!-- Master Parking -->
  <node name="Master_parking" pkg="control" type="Master_parking" output="screen"/>
  
</launch>
